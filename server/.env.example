# FoodSense Server Environment Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git.

# ─── Database ──────────────────────────────────────────────────────────
# When running via docker-compose, use 'postgres' as the hostname.
# When running locally, use 'localhost'.
DATABASE_URL="postgresql://postgres:CHANGE_ME_STRONG_PASSWORD@postgres:5432/foodsense?schema=public"
POSTGRES_PASSWORD="CHANGE_ME_STRONG_PASSWORD"

# ─── Redis ─────────────────────────────────────────────────────────────
REDIS_URL="redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379"
REDIS_PASSWORD="CHANGE_ME_REDIS_PASSWORD"

# ─── Authentication ───────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET="CHANGE_ME_64_CHAR_HEX_STRING"

# ─── AI (Optional) ─────────────────────────────────────────────────────
# Server-side Gemini proxy. Leave empty — users bring their own API keys.
# Only set this if you want the server to proxy AI calls for users without keys.
GEMINI_API_KEY=""

# ─── Firebase ──────────────────────────────────────────────────────────
# Path to your Firebase service account JSON (downloaded from Firebase Console).
# The file is bind-mounted into the container at /app/firebase-service-account.json.
FIREBASE_SERVICE_ACCOUNT_PATH="./firebase-service-account.json"
FIREBASE_STORAGE_BUCKET="your-project-id.firebasestorage.app"

# ─── Server ────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Logging & Observability (Optional) ───────────────────────────────
# LOG_LEVEL=info
# SENTRY_DSN=
