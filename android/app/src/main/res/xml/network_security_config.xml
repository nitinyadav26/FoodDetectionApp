<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Dev-only: allow cleartext HTTP to the FoodSense dev server.
         Remove this domain-config once the server is served over HTTPS. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">159.65.154.224</domain>
        <!-- Also permit emulator loopback for local dev -->
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
